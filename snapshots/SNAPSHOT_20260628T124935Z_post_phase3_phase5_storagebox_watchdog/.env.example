# ════════════════════════════════════════════════════════════════
# Paper Trading — Environment Variables Template
# ════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:           cp .env.example .env
# 2. Replace the placeholders below with your real values
# 3. NEVER commit .env (it's already in .gitignore)
# ════════════════════════════════════════════════════════════════

# === Telegram Bot ===
# Get token from @BotFather (/newbot or /token to retrieve existing)
# Get chat_id from @userinfobot (just send /start)
TELEGRAM_BOT_TOKEN=paste_your_token_here
TELEGRAM_CHAT_ID=paste_your_chat_id_here

# === Capital ===
# Starting paper capital in USD
INITIAL_CAPITAL=1000

# === Logging ===
# Levels: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === Dev / Debug (leave empty for normal operation) ===
# DEV_FAST_MODE=1  # Uncomment to process bars faster during tests
