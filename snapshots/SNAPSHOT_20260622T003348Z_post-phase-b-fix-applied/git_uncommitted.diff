+    # The per-trade gross_funding sums the SAME funding_pnl that the vectorised
+    # equity curve sees, so it must use the lag-shifted funding rate.
+    shifted_funding = funding.shift(1).fillna(0)
     trades = []
     for entry_t, exit_t in zip(entries_idx, exits_idx):
