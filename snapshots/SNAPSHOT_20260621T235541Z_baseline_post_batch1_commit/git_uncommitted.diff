+            return TelegramResult(ok=False, error="telegram_not_configured")
+
+        if caption and len(caption) > 1024:
+            caption = caption[:1020] + "..."
+
+        url = f"{self.BASE_URL}/bot{self.token}/sendPhoto"
+        try:
